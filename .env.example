# Cliniko API key — generated in Cliniko admin → My Info → Manage API keys.
# Shard (au1, au2, au3, au4, uk1, uk2, us1, ca1) is auto-detected from the key suffix.
# Get one from a paid Cliniko sandbox (~$45/mo) for development.
CLINIKO_API_KEY=

# Contact email surfaced in the User-Agent header on every Cliniko request.
# Cliniko docs explicitly warn that requests without an identifying User-Agent
# may be blocked. Use a per-clinic or per-developer email here.
CLINIKO_USER_AGENT_EMAIL=

# Optional — override the Cliniko API base URL. Leave blank to auto-detect from shard.
CLINIKO_BASE_URL=

# Optional — Postgres URL for the audit log. If unset, audit logging is disabled.
# Format: postgresql://user:pass@host:port/db
AUDIT_LOG_DATABASE_URL=

# Optional — Fernet encryption key for the per-tenant vault (Phase C).
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
VAULT_ENCRYPTION_KEY=
